<resources>
    <color name="myra_border">#1A1A2E</color>
    <color name="myra_card">#0D0D1A</color>
    <color name="myra_card_2">#111124</color>
    <color name="myra_cyan">#00E5FF</color>
    <color name="myra_cyan_dark">#00B8D4</color>
    <color name="myra_dark">#040408</color>
    <color name="myra_dark_2">#08080F</color>
    <color name="myra_glow_cyan">#4400E5FF</color>
    <color name="myra_glow_purple">#44D500F9</color>
    <color name="myra_glow_red">#44FF1744</color>
    <color name="myra_hint">#444466</color>
    <color name="myra_idle">#FF1744</color>
    <color name="myra_listening">#00E5FF</color>
    <color name="myra_purple">#D500F9</color>
    <color name="myra_purple_light">#EA80FF</color>
    <color name="myra_red">#FF1744</color>
    <color name="myra_red_dark">#B71C1C</color>
    <color name="myra_red_soft">#FF6D6D</color>
    <color name="myra_speaking">#FF1744</color>
    <color name="myra_text">#E8E8FF</color>
    <color name="myra_text_dim">#888899</color>
    <color name="myra_thinking">#D500F9</color>
    <string name="accessibility_disabled">Accessibility: Disabled ⚠️</string>
    <string name="accessibility_enabled">Accessibility: Active ✅</string>
    <string name="api_key_hint">Enter Gemini API Key</string>
    <string name="app_name">MYRA</string>
    <string name="app_tagline">AI COMPANION</string>
    <string name="listening">LISTENING…</string>
    <string name="long_press_stop">Hold to reconnect</string>
    <string name="myra_full">M · Y · R · A</string>
    <string name="save">SAVE SETTINGS</string>
    <string name="settings">Settings</string>
    <string name="speaking">SPEAKING…</string>
    <string name="system_ready">SYSTEM READY</string>
    <string name="thinking">THINKING…</string>
    <style name="MyraStatus">
        <item name="android:fontFamily">monospace</item>
        <item name="android:letterSpacing">0.15</item>
        <item name="android:textSize">11sp</item>
        <item name="android:alpha">0.85</item>
    </style>
    <style name="MyraSubtitle">
        <item name="android:fontFamily">monospace</item>
        <item name="android:letterSpacing">0.4</item>
        <item name="android:textColor">@color/myra_hint</item>
        <item name="android:textSize">9sp</item>
    </style>
    <style name="MyraTitle">
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:letterSpacing">0.35</item>
        <item name="android:textColor">@color/myra_red</item>
        <item name="android:textSize">26sp</item>
    </style>
    <style name="PinButton">
        <item name="android:layout_width">80dp</item>
        <item name="android:layout_height">80dp</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textColor">@color/myra_text</item>
        <item name="android:background">@android:color/transparent</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="Theme.Myra" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@color/myra_dark</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/myra_dark</item>
        <item name="colorPrimary">@color/myra_red</item>
        <item name="colorPrimaryDark">@color/myra_red_dark</item>
        <item name="colorAccent">@color/myra_purple</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:textColorPrimary">@color/myra_text</item>
        <item name="android:textColorHint">@color/myra_hint</item>
        <item name="editTextColor">@color/myra_text</item>
        <item name="colorControlActivated">@color/myra_cyan</item>
        <item name="colorControlHighlight">@color/myra_glow_cyan</item>
    </style>
    <style name="Theme.Myra.Transparent" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>
</resources>